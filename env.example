# =============================================================================
# Psicología IA - Environment Configuration
# =============================================================================
#
# Copy this file to .env and fill in your values.
# NEVER commit .env to git (it contains secrets)
#

# =============================================================================
# DATA DIRECTORY (CRITICAL)
# =============================================================================
# This should point to a directory OUTSIDE the git repository
# where patient data is stored. This keeps sensitive data separate.

PSICOLOGIA_DATA_DIR=/ruta/a/tus/datos/PsicologiaIA-DATA

# =============================================================================
# WHISPER SETTINGS
# =============================================================================
# Model options: tiny, base, small, medium, large, turbo
# Larger models are more accurate but slower and need more VRAM

WHISPER_MODEL=base
WHISPER_LANGUAGE=es
TRANSCRIPTION_WORKERS=4

# =============================================================================
# API KEYS (Required for AI Analysis Features)
# =============================================================================
# Get your keys from:
# - OpenAI: https://platform.openai.com/api-keys
# - Anthropic: https://console.anthropic.com/settings/keys

OPENAI_API_KEY=sk-...
ANTHROPIC_API_KEY=sk-ant-...

# =============================================================================
# OPTIONAL: FFMPEG PATH
# =============================================================================
# Only needed if FFmpeg is not in your PATH
# Usually installed via: winget install Gyan.FFmpeg (Windows)

# FFMPEG_PATH=C:\ffmpeg\bin
