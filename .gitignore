# =============================================================================
# LourdesBusiness .gitignore
# Private repo - patient data IS tracked (owner's data for examples)
# =============================================================================

# =============================================================================
# PYTHON
# =============================================================================

__pycache__/
*.py[cod]
*$py.class
*.so
.Python
build/
develop-eggs/
dist/
downloads/
eggs/
.eggs/
lib/
lib64/
parts/
sdist/
var/
wheels/
*.egg-info/
.installed.cfg
*.egg

# Virtual environments
venv/
.venv/
ENV/
env/

# Type checking
.mypy_cache/
.dmypy.json
dmypy.json
.pyre/

# Testing
.pytest_cache/
.coverage
htmlcov/
.tox/
.nox/

# Jupyter
.ipynb_checkpoints/

# =============================================================================
# ENVIRONMENT & SECRETS
# =============================================================================

.env
.env.local
.env.*.local
*.pem
*.key
*.crt
secrets.yaml
secrets.json
credentials.json

# =============================================================================
# IDE & EDITORS
# =============================================================================

.vscode/
.idea/
*.swp
*.swo
*~
.project
.pydevproject
.settings/

# =============================================================================
# OS FILES
# =============================================================================

# Windows
nul
Thumbs.db
ehthumbs.db
Desktop.ini
$RECYCLE.BIN/

# macOS
.DS_Store
.AppleDouble
.LSOverride
._*

# Linux
.fuse_hidden*
.directory

# =============================================================================
# TEMPORARY FILES
# =============================================================================

*.tmp
*.temp
*.bak
*.backup
*.log
logs/

# =============================================================================
# DOCUMENTATION BUILD
# =============================================================================

docs/_build/
site/
